# Base URL of the AmanGuard Spring Boot backend
VITE_API_BASE_URL=http://localhost:8080/api

# ── AI fraud-analysis engine (Java backend → Python engine) ─────────────────
# Read by the Java backend from OS env vars. Both are optional: the backend
# defaults to http://localhost:8000 and sends NO Authorization header while
# AI_API_KEY is blank (the current engine is keyless).
AI_ENGINE_URL=http://localhost:8000
AI_API_KEY=

# ── Python AI engine (AI/phishingGPT.py) ────────────────────────────────────
# The engine loads this from the gitignored root .env (python-dotenv) to call
# OpenAI. Keep the real key in .env only — never commit it, never put it in Java.
OPENAI_API_KEY=your-openai-key-here
